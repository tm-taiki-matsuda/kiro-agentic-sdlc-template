{
  "name": "shared-package",
  "description": "An agent that safely adds type definitions and constants to the shared package. Breaking changes (deleting or renaming existing types) are prohibited.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/shared-package.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "task"
  ],
  "allowedTools": [
    "code",
    "fs_read",
    "glob",
    "grep",
    "task"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "shared/src/**",
        "shared/constants/**",
        "tasks/**"
      ],
      "deniedPaths": [
        "**/.env",
        "**/.env.*",
        "**/package-lock.json",
        "**/*.secrets.*",
        "**/azure-pipelines-*.yml",
        "**/.github/workflows/*.yml",
        "**/.gitlab-ci.yml"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://tasks/todo.md",
    "file://tasks/lessons.md",
    "skill://.kiro/skills/tech-stack/SKILL.md",
    "skill://.kiro/skills/product-context/SKILL.md",
    "skill://.kiro/skills/code-structure/SKILL.md",
    "skill://.kiro/skills/security-constraints/SKILL.md",
    "skill://.kiro/skills/dev-workflow/SKILL.md",
    "skill://.kiro/skills/adr-quick-reference/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start-hook.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git branch --show-current 2>/dev/null && git diff --stat HEAD 2>/dev/null | tail -1 && ls -d .kiro/specs/*/requirements.md 2>/dev/null | head -5 | sed 's/^/📋 /'",
        "cache_ttl_seconds": 30
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/scripts/stop-hook.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/security-hook.sh"
      },
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/guard-schema-hook.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/prettier-hook.sh",
        "timeout_ms": 15000
      }
    ]
  },
  "keyboardShortcut": "ctrl+shift+s",
  "welcomeMessage": "Adding types and constants to shared package. Changes limited to shared/ only. Breaking changes (deletion/rename) are prohibited."
}
