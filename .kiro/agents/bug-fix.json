{
  "name": "bug-fix",
  "description": "An autonomous agent that identifies the root cause of bugs and fixes them with minimal impact.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/bug-fix.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "task",
    "code",
    "knowledge"
  ],
  "allowedTools": [
    "code",
    "fs_read",
    "glob",
    "grep",
    "knowledge",
    "task"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "backend/src/**",
        "backend/tests/**",
        "frontend/src/**",
        "frontend/tests/**",
        "functions/src/**",
        "functions/tests/**",
        "shared/src/**",
        "shared/constants/**",
        "tasks/**"
      ],
      "deniedPaths": [
        "**/.env",
        "**/.env.*",
        "**/package-lock.json",
        "**/*.secrets.*",
        "**/azure-pipelines-*.yml",
        "**/.github/workflows/*.yml",
        "**/.gitlab-ci.yml"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://tasks/todo.md",
    "file://tasks/lessons.md",
    {
      "type": "knowledgeBase",
      "source": "file://./design",
      "name": "Design Documents",
      "indexType": "best",
      "include": [
        "**/*.md",
        "**/*.yaml"
      ],
      "exclude": [
        "**/context/**",
        "**/tmp/**",
        "**/review/**",
        "**/old/**",
        "**/issues/**",
        "**/md/**"
      ],
      "autoUpdate": true
    },
    "skill://.kiro/skills/tech-stack/SKILL.md",
    "skill://.kiro/skills/code-structure/SKILL.md",
    "skill://.kiro/skills/security-constraints/SKILL.md",
    "skill://.kiro/skills/test-framework/SKILL.md",
    "skill://.kiro/skills/error-handling-pattern/SKILL.md",
    "skill://.kiro/skills/dev-workflow/SKILL.md",
    "skill://.kiro/skills/workflow-diagrams/SKILL.md",
    "skill://.kiro/skills/product-context/SKILL.md",
    "skill://.kiro/skills/adr-quick-reference/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start-hook.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git branch --show-current 2>/dev/null && git diff --stat HEAD 2>/dev/null | tail -1 && ls -d .kiro/specs/*/requirements.md 2>/dev/null | head -5 | sed 's/^/📋 /'",
        "cache_ttl_seconds": 30
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/scripts/stop-hook.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/security-hook.sh"
      },
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/guard-schema-hook.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/prettier-hook.sh",
        "timeout_ms": 15000
      },
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/test-summary-hook.sh"
      }
    ]
  },
  "keyboardShortcut": "ctrl+shift+x",
  "welcomeMessage": "Identifying root cause and applying minimal fix. Can handle backend/frontend/functions cross-layer."
}
