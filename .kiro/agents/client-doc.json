{
  "name": "client-doc",
  "description": "An interactive agent that generates client-facing documentation (current specs, improvement proposals, effort estimates) in HTML format. Cross-references implementation code and design documents to produce accurate materials.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/client-doc.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "task",
    "code",
    "knowledge"
  ],
  "allowedTools": [
    "code",
    "fs_read",
    "glob",
    "grep",
    "knowledge",
    "task"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "output/**",
        "tasks/**"
      ],
      "deniedPaths": [
        "**/.env",
        "**/.env.*",
        "**/package-lock.json",
        "**/*.secrets.*",
        "**/azure-pipelines-*.yml",
        "**/.github/workflows/*.yml",
        "**/.gitlab-ci.yml"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://tasks/todo.md",
    "file://tasks/lessons.md",
    {
      "type": "knowledgeBase",
      "source": "file://./design",
      "name": "Design Documents",
      "indexType": "best",
      "include": [
        "**/*.md",
        "**/*.yaml"
      ],
      "exclude": [
        "**/context/**",
        "**/tmp/**",
        "**/review/**",
        "**/old/**",
        "**/issues/**",
        "**/md/**"
      ],
      "autoUpdate": true
    },
    "skill://.kiro/skills/product-context/SKILL.md",
    "skill://.kiro/skills/tech-stack/SKILL.md",
    "skill://.kiro/skills/code-structure/SKILL.md",
    "skill://.kiro/skills/security-constraints/SKILL.md",
    "skill://.kiro/skills/workflow-diagrams/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start-hook.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git branch --show-current 2>/dev/null && git diff --stat HEAD 2>/dev/null | tail -1 && ls output/*.html 2>/dev/null | tail -5 | sed 's/^/📄 /'",
        "cache_ttl_seconds": 30
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/scripts/stop-hook.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/security-hook.sh"
      },
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/guard-schema-hook.sh"
      }
    ]
  },
  "mcpServers": {
    "design-docs": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "${DESIGN_DIR}"
      ],
      "disabledTools": [
        "write_file",
        "create_directory",
        "move_file"
      ]
    }
  },
  "keyboardShortcut": "ctrl+shift+c",
  "welcomeMessage": "Creating client-facing documentation.\nWhat type of document do you need? (current spec explanation / improvement proposal / effort estimate / comparison table / etc.)\nPlease tell me the target screen or feature name."
}
