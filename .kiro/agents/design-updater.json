{
  "name": "design-updater",
  "description": "An agent that updates design documents under design/ based on requirement memos, meeting notes, or implementation drift. All changes follow a draft-present → developer-approval flow.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/design-updater.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "task",
    "knowledge"
  ],
  "allowedTools": [
    "code",
    "fs_read",
    "glob",
    "grep",
    "knowledge",
    "task"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "design/**",
        "tasks/**"
      ],
      "deniedPaths": [
        "**/.env",
        "**/.env.*",
        "**/package-lock.json",
        "**/*.secrets.*",
        "**/azure-pipelines-*.yml",
        "**/.github/workflows/*.yml",
        "**/.gitlab-ci.yml"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://tasks/todo.md",
    "file://tasks/lessons.md",
    {
      "type": "knowledgeBase",
      "source": "file://./design",
      "name": "Design Documents",
      "indexType": "best",
      "include": [
        "**/*.md",
        "**/*.yaml"
      ],
      "exclude": [
        "**/context/**",
        "**/tmp/**",
        "**/review/**",
        "**/old/**",
        "**/issues/**",
        "**/md/**"
      ],
      "autoUpdate": true
    },
    "skill://.kiro/skills/product-context/SKILL.md",
    "skill://.kiro/skills/tech-stack/SKILL.md",
    "skill://.kiro/skills/code-structure/SKILL.md",
    "skill://.kiro/skills/security-constraints/SKILL.md",
    "skill://.kiro/skills/dev-workflow/SKILL.md",
    "skill://.kiro/skills/workflow-diagrams/SKILL.md",
    "skill://.kiro/skills/adr-quick-reference/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start-hook.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git branch --show-current 2>/dev/null && git diff --stat HEAD 2>/dev/null | tail -1 && ls -d .kiro/specs/*/requirements.md 2>/dev/null | head -5 | sed 's/^/📋 /'",
        "cache_ttl_seconds": 30
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/scripts/stop-hook.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/security-hook.sh"
      }
    ]
  },
  "mcpServers": {
    "design-docs": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "${DESIGN_DIR}"
      ],
      "disabledTools": [
        "write_file",
        "create_directory",
        "move_file"
      ]
    }
  },
  "keyboardShortcut": "ctrl+shift+u",
  "welcomeMessage": "Updating design documents. Changes limited to design/ only. Does not touch implementation code. All changes follow draft-present → approval flow."
}
