{
  "name": "db-migration",
  "description": "An agent that safely performs Prisma schema changes and migration execution. Only edits the schema source file and always requires developer approval before running.",
  "model": "claude-sonnet-4.6",
  "prompt": "file://../prompts/db-migration.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "task"
  ],
  "allowedTools": [
    "code",
    "fs_read",
    "glob",
    "grep",
    "task"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "database/**",
        "tasks/**"
      ],
      "deniedPaths": [
        "**/.env",
        "**/.env.*",
        "**/package-lock.json",
        "**/*.secrets.*",
        "**/azure-pipelines-*.yml",
        "**/.github/workflows/*.yml",
        "**/.gitlab-ci.yml"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://tasks/todo.md",
    "file://tasks/lessons.md",
    "skill://.kiro/skills/tech-stack/SKILL.md",
    "skill://.kiro/skills/security-constraints/SKILL.md",
    "skill://.kiro/skills/dev-workflow/SKILL.md",
    "skill://.kiro/skills/prisma-repository-pattern/SKILL.md",
    "skill://.kiro/skills/adr-quick-reference/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start-hook.sh"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "git branch --show-current 2>/dev/null && git diff --stat HEAD 2>/dev/null | tail -1",
        "cache_ttl_seconds": 30
      }
    ],
    "stop": [
      {
        "command": "bash .kiro/scripts/stop-hook.sh"
      }
    ],
    "preToolUse": [
      {
        "matcher": "shell",
        "command": "bash .kiro/scripts/security-hook.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/prettier-hook.sh",
        "timeout_ms": 15000
      },
      {
        "matcher": "write",
        "command": "bash .kiro/scripts/schema-change-hook.sh"
      }
    ]
  },
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-postgres@0.6.2"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "design-docs": {
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "${DESIGN_DIR}"
      ],
      "disabledTools": [
        "write_file",
        "create_directory",
        "move_file"
      ]
    }
  },
  "keyboardShortcut": "ctrl+shift+d",
  "welcomeMessage": "Safely executing DB schema changes. Edits limited to the schema source directory only. Apply runs only after approval."
}
